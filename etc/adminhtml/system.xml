<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="hyva_theme_grid" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="10" translate="label">
            <label>Hyva Admin Grid</label>
            <tab>hyva_themes</tab>
            <resource>Hyva_AdminTest::test</resource>

            <group id="grid" translate="label comment" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Admin Grid</label>
                <field id="menu_fast" translate="label" type="select" sortOrder="1" showInDefault="1" showInStore="0" showInWebsite="0">
                    <label>Fast menu access</label>
                    <comment><![CDATA[Show or not the fast menu access in the admin panel.]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
