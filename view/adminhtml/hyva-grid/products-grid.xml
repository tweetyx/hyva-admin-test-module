<grid xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Hyva_Admin:etc/hyva-grid.xsd">
    <source>
        <repositoryListMethod>\Magento\Catalog\Api\ProductRepositoryInterface::getList</repositoryListMethod>
        <processors>
            <processor class="\Hyva\AdminTest\HyvaGridProcessor\ProductGridQueryProcessor"/>
        </processors>
    </source>
    <columns rowAction="test">
        <include>
            <column name="id"/>
            <column name="thumbnail" type="magento_product_image" renderAsUnsecureHtml="true" label="Thumbnail" sortable="false"/>
            <column name="name" label="Name"/>
            <column name="type_id" label="Type" source="Magento\Catalog\Model\Product\Type"/>
            <column name="attribute_set_id" label="Attribute Set" source="Magento\Catalog\Model\Product\AttributeSet\Options"/>
            <column name="sku"/>
            <column name="price" type="price"/>
            <!-- <column name="qty" label="Quantity" type="Hyva\AdminTest\Model\QtyValueProcessor"/> -->
            <column name="visibility" source="Magento\Catalog\Model\Product\Visibility"/>
            <column name="status" label="Status" source="Magento\Catalog\Model\Product\Attribute\Source\Status"/>
            <column name="website_ids" label="Websites" type="website_id" source="Magento\Store\Model\ResourceModel\Website\Collection"/>
        </include>
        <exclude>
            <column name="category_gear"/>
        </exclude>
    </columns>
    <actions idColumn="id">
        <action id="edit" label="Edit" url="catalog/product/edit"/>
        <action id="delete" label="Delete" url="catalog/product/delete"/>
        <!-- <action id="test" label="Test" url="*/*/dumpqueryvars"/> -->
    </actions>
    <massActions idColumn="id" idsParam="ids">
        <!-- <action id="test" label="Test Query Params" url="*/*/dumpqueryvars"/> -->
        <action id="reindex" label="Reindex" url="catalog/massAction/reindex"/>
        <action id="delete" label="Delete" url="catalog/product/massDelete" requireConfirmation="true"/>
    </massActions>
    <entityConfig>
        <label>
            <singular>Product</singular>
            <plural>Products</plural>
        </label>
    </entityConfig>
    <navigation>
        <exports>
            <export type="csv" label="Export as CSV"/>
            <export type="xml"/>
            <export type="xlsx" label="Export as XLSX"/>
        </exports>
        <pager>
            <defaultPageSize>5</defaultPageSize>
            <pageSizes>2, 5, 10</pageSizes>
        </pager>
        <buttons>
            <button id="add" url="catalog/product/new/set/4/type/simple"/>
            <button id="refresh" label="Refresh Page" onclick="window.location.reload(true)" sortOrder="-1"/>
        </buttons>
        <sorting>
            <defaultSortByColumn>foo</defaultSortByColumn>
            <defaultSortDirection>desc</defaultSortDirection>
        </sorting>
        <filters>
            <filter column="id"/>
            <filter column="name"/>
            <filter column="sku"/>
            <filter column="type_id"/>
            <filter column="attribute_set_id"/>
            <filter column="visibility"/>
            <filter column="status"/>
            <filter column="website_ids"/>
        </filters>
    </navigation>
</grid>
